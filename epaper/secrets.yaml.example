# Kopiere diese Datei nach secrets.yaml und trage deine Werte ein.
# secrets.yaml wird nicht ins Repository eingecheckt.

# Wi-Fi
wifi_ssid: "Mein-WLAN"
wifi_password: "mein-passwort"

# ESPHome API & OTA (aus ESPHome Dashboard generieren oder manuell setzen)
api_encryption_key: "base64encodedkey=="
ota_password: ""
ap_password: ""

# Nachbarschaft-Laden E-Paper – Konfiguration
# URL zum display_combined.png: basis_url (aus Add-on-Konfig) + /local/display_combined.png
epaper_display_image_url: "https://meine-domain.de/local/display_combined.png"

# QR-Code URL: entspricht qr_code_url in der Add-on-Konfiguration
epaper_qr_url: "https://meine-domain.de/local/nachbarschaft-laden/index.html"

# PV-Prognose-Sensoren: müssen sensor_pv_morgen/uebermorgen/in3tagen
# aus der Add-on-Konfiguration entsprechen
epaper_sensor_pv_morgen:      "sensor.morgenpv"
epaper_sensor_pv_uebermorgen: "sensor.uebermorgenpv"
epaper_sensor_pv_in3tagen:    "sensor.pvin3tagen"
